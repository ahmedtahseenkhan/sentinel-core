<!--
  ============================================================================
  SentinelCore - Custom Detection Rules
  ============================================================================
  Add custom rules below. Rules use IDs 100000-120000 (local rule range).
  Reference: https://documentation.wazuh.com/current/user-manual/ruleset/
  ============================================================================
-->

<group name="sentinelcore,custom_rules,">

  <!-- ============================= -->
  <!-- SentinelCore Custom Alerts    -->
  <!-- ============================= -->

  <!-- Alert on new agent connection -->
  <rule id="100001" level="3">
    <if_sid>503</if_sid>
    <description>SentinelCore: New agent connected to the manager.</description>
    <group>sentinelcore,agent_connection,</group>
  </rule>

  <!-- Alert on agent disconnection -->
  <rule id="100002" level="7">
    <if_sid>504</if_sid>
    <description>SentinelCore: Agent disconnected from the manager.</description>
    <group>sentinelcore,agent_disconnection,</group>
  </rule>

  <!-- ============================= -->
  <!-- Brute Force Detection         -->
  <!-- ============================= -->

  <!-- Multiple authentication failures from same source -->
  <rule id="100010" level="10" frequency="8" timeframe="120">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>SentinelCore: Brute force attack detected - $(srcip).</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>sentinelcore,brute_force,authentication_failures,</group>
  </rule>

  <!-- SSH brute force (multiple failed SSH logins) -->
  <rule id="100011" level="10" frequency="10" timeframe="120">
    <if_matched_sid>5763</if_matched_sid>
    <same_source_ip />
    <description>SentinelCore: SSH brute force attack from $(srcip).</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>sentinelcore,brute_force,ssh,</group>
  </rule>

  <!-- ============================= -->
  <!-- File Integrity Rules          -->
  <!-- ============================= -->

  <!-- Critical system file modified -->
  <rule id="100020" level="12">
    <if_sid>550</if_sid>
    <match>/etc/passwd|/etc/shadow|/etc/sudoers</match>
    <description>SentinelCore: Critical system file modified - $(file).</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>sentinelcore,file_integrity,critical_file,</group>
  </rule>

  <!-- Web application file change -->
  <rule id="100021" level="8">
    <if_sid>554</if_sid>
    <match>/var/www|/usr/share/nginx</match>
    <description>SentinelCore: Web application file change detected - $(file).</description>
    <mitre>
      <id>T1505.003</id>
    </mitre>
    <group>sentinelcore,file_integrity,web_application,</group>
  </rule>

  <!-- ============================= -->
  <!-- Privilege Escalation          -->
  <!-- ============================= -->

  <!-- Successful sudo to root -->
  <rule id="100030" level="5">
    <if_sid>5401</if_sid>
    <match>root</match>
    <description>SentinelCore: User $(srcuser) escalated to root via sudo.</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>sentinelcore,privilege_escalation,sudo,</group>
  </rule>

  <!-- Unauthorized sudo attempt -->
  <rule id="100031" level="10">
    <if_sid>5403</if_sid>
    <description>SentinelCore: Unauthorized sudo attempt by $(srcuser).</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>sentinelcore,privilege_escalation,unauthorized_sudo,</group>
  </rule>

  <!-- ============================= -->
  <!-- Malware / Rootkit Detection   -->
  <!-- ============================= -->

  <!-- Rootkit detected -->
  <rule id="100040" level="15">
    <if_sid>510</if_sid>
    <description>SentinelCore: Rootkit detected on host $(hostname)!</description>
    <mitre>
      <id>T1014</id>
    </mitre>
    <group>sentinelcore,rootkit,malware,</group>
  </rule>

  <!-- Trojan detected -->
  <rule id="100041" level="15">
    <if_sid>511</if_sid>
    <description>SentinelCore: Trojan detected on host $(hostname)!</description>
    <mitre>
      <id>T1036</id>
    </mitre>
    <group>sentinelcore,trojan,malware,</group>
  </rule>

  <!-- ============================= -->
  <!-- Network Anomalies             -->
  <!-- ============================= -->

  <!-- New listening port detected -->
  <rule id="100050" level="7">
    <if_sid>533</if_sid>
    <description>SentinelCore: New listening port detected on $(hostname).</description>
    <mitre>
      <id>T1571</id>
    </mitre>
    <group>sentinelcore,network,new_port,</group>
  </rule>

  <!-- ============================= -->
  <!-- Compliance Monitoring         -->
  <!-- ============================= -->

  <!-- PCI-DSS Requirement 10 - Log monitoring -->
  <rule id="100060" level="5">
    <if_sid>5501</if_sid>
    <description>SentinelCore: PCI-DSS (Req 10) - Log entry detected for audit trail.</description>
    <group>sentinelcore,pci_dss_10.2.4,compliance,</group>
  </rule>

  <!-- Password policy violation -->
  <rule id="100061" level="8">
    <if_sid>5555</if_sid>
    <description>SentinelCore: Password policy violation detected.</description>
    <group>sentinelcore,pci_dss_8.2.3,compliance,password_policy,</group>
  </rule>

</group>
