{
  "description": "SentinelCore Alerts Ingest Pipeline",
  "processors": [
    {
      "date": {
        "field": "timestamp",
        "target_field": "@timestamp",
        "formats": ["ISO8601", "yyyy-MM-dd'T'HH:mm:ssZ", "yyyy-MM-dd HH:mm:ss"],
        "ignore_failure": true
      }
    },
    {
      "geoip": {
        "field": "data.srcip",
        "target_field": "GeoLocation",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "set": {
        "field": "sentinelcore.company",
        "value": "SENTINELCORE_COMPANY",
        "override": false
      }
    },
    {
      "set": {
        "field": "sentinelcore.environment",
        "value": "production",
        "override": false
      }
    },
    {
      "script": {
        "description": "Set severity level based on rule level",
        "lang": "painless",
        "source": "if (ctx.rule != null && ctx.rule.level != null) { int level = ctx.rule.level; if (level >= 12) { ctx.sentinelcore_severity = 'critical'; } else if (level >= 8) { ctx.sentinelcore_severity = 'high'; } else if (level >= 5) { ctx.sentinelcore_severity = 'medium'; } else { ctx.sentinelcore_severity = 'low'; } }",
        "ignore_failure": true
      }
    },
    {
      "lowercase": {
        "field": "data.srcuser",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "remove": {
        "field": ["_temp"],
        "ignore_missing": true,
        "ignore_failure": true
      }
    }
  ],
  "on_failure": [
    {
      "set": {
        "field": "sentinelcore.pipeline_error",
        "value": "{{ _ingest.on_failure_message }}"
      }
    }
  ]
}
