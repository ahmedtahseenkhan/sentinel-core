<!--
  ============================================================================
  SentinelCore - PCI DSS Compliance Rules
  ============================================================================
  Custom rules for PCI DSS compliance monitoring.
  Reference: PCI DSS v4.0
  ============================================================================
-->

<group name="sentinelcore,pci_dss,">

  <!-- Requirement 1: Network Security Controls -->
  <rule id="110001" level="8">
    <if_sid>5710</if_sid>
    <description>SentinelCore PCI-DSS 1.3: Unauthorized network access attempt detected.</description>
    <group>pci_dss_1.3,network_access,</group>
  </rule>

  <!-- Requirement 2: Secure Configurations -->
  <rule id="110010" level="7">
    <if_sid>550</if_sid>
    <match>/etc/ssh/sshd_config</match>
    <description>SentinelCore PCI-DSS 2.2: SSH configuration file modified.</description>
    <group>pci_dss_2.2,config_change,</group>
  </rule>

  <!-- Requirement 5: Anti-Malware -->
  <rule id="110020" level="12">
    <if_sid>510</if_sid>
    <description>SentinelCore PCI-DSS 5.2: Malware/rootkit detected on system.</description>
    <group>pci_dss_5.2,malware,</group>
  </rule>

  <!-- Requirement 6: Secure Development -->
  <rule id="110030" level="8">
    <if_sid>554</if_sid>
    <match>/var/www</match>
    <description>SentinelCore PCI-DSS 6.4: Web application file change detected.</description>
    <group>pci_dss_6.4,web_change,</group>
  </rule>

  <!-- Requirement 7: Restrict Access -->
  <rule id="110040" level="10">
    <if_sid>5403</if_sid>
    <description>SentinelCore PCI-DSS 7.1: Unauthorized access attempt - sudo violation.</description>
    <group>pci_dss_7.1,unauthorized_access,</group>
  </rule>

  <!-- Requirement 8: Identify Users -->
  <rule id="110050" level="10" frequency="8" timeframe="120">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>SentinelCore PCI-DSS 8.3: Brute force attack - multiple failed authentications.</description>
    <group>pci_dss_8.3,brute_force,</group>
  </rule>

  <!-- Requirement 10: Log and Monitor -->
  <rule id="110060" level="5">
    <if_sid>5501</if_sid>
    <description>SentinelCore PCI-DSS 10.2: Audit trail event recorded.</description>
    <group>pci_dss_10.2,audit,</group>
  </rule>

  <rule id="110061" level="10">
    <if_sid>521</if_sid>
    <description>SentinelCore PCI-DSS 10.5: Audit log integrity issue detected.</description>
    <group>pci_dss_10.5,log_integrity,</group>
  </rule>

  <!-- Requirement 11: Security Testing -->
  <rule id="110070" level="7">
    <if_sid>533</if_sid>
    <description>SentinelCore PCI-DSS 11.5: New listening port detected - potential vulnerability.</description>
    <group>pci_dss_11.5,new_port,</group>
  </rule>

</group>
